rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 게시글 사진: 누구나 읽기 가능 (카카오 공유 카드 등 외부 접근 포함),
    // 쓰기(업로드)는 로그인한 사용자만.
    match /items/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 나머지 경로는 전부 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
