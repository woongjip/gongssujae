rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 물건 사진: 누구나 읽기, 로그인 사용자 업로드 (이미지·5MB 이하)
    match /items/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 일자리 사진: items와 동일한 규칙 (누락되어 업로드가 차단 상태였음)
    match /jobs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 나머지 경로는 전부 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
