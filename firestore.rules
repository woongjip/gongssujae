rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 물건: 누구나 읽기 / 로그인 사용자 등록 / 소유자 or likedBy만 수정
    match /items/{itemId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.sellerId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['chatCount'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.sellerId;
    }

    // 일자리: 누구나 읽기 / 로그인 사용자 등록 / 소유자만 수정·삭제
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.sellerId;
    }

    // 유저: 로그인 사용자 읽기 / 본인만 쓰기
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // 채팅방: 참여자만 읽기·쓰기
    match /chats/{chatId} {
      allow read, update: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // 신고: 로그인 사용자 읽기·쓰기
    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }
  }
}
