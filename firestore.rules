rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // items: 비로그인도 읽기 허용, write는 로그인 필요
    match /items/{itemId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn()
                    && (
                      resource.data.sellerId == request.auth.uid
                      ||
                      (
                        resource.data.sellerId != request.auth.uid
                        && (
                          (
                            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy'])
                            && request.resource.data.likedBy.toSet()
                                 .difference(resource.data.likedBy.toSet())
                                 .union(resource.data.likedBy.toSet()
                                 .difference(request.resource.data.likedBy.toSet()))
                                 .hasOnly([request.auth.uid])
                          )
                          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['chatCount'])
                          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
                        )
                      )
                    );
      allow delete: if isSignedIn()
                    && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    // jobs: 비로그인도 읽기 허용, write는 로그인 필요
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.sellerId == request.auth.uid;
      allow delete: if isSignedIn()
                    && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    // itemPrivate: 게시글 연락처 — 어드민만 읽기, 작성자 쓰기
    match /itemPrivate/{itemId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn()
                    && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn()
                    && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    // userPrivate: phone 등 민감정보 — 본인 또는 어드민만 읽기/쓰기
    match /userPrivate/{userId} {
      allow get: if request.auth != null
                 && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // users: 본인 쓰기 + 어드민 예외
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;

      // 본인 수정: isAdmin, status는 본인이 못 바꿈 (악용 차단)
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.isAdmin == resource.data.isAdmin
                    && request.resource.data.status == resource.data.status;

      // 어드민은 남의 문서 status/isAdmin 변경 가능 (계정 정지, 어드민 임명)
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;

      allow delete: if false;
    }

    // chats: read는 chatId 기반(list 쿼리 안정), write는 participants 기반
    match /chats/{chatId} {
      // list(구독 쿼리): participants 기반 — 쿼리와 규칙 기준 일치
      allow list: if isSignedIn()
                  && request.auth.uid in resource.data.participants;
      // get(단건 읽기): 문서가 없을 때(resource==null)도 허용 — openChat getDoc 체크
      allow get: if isSignedIn()
                 && (resource == null
                     || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn()
                    && (chatId.split('_')[0] == request.auth.uid
                        || chatId.split('_')[1] == request.auth.uid);
        allow create: if isSignedIn()
                      && request.resource.data.from == request.auth.uid
                      && (chatId.split('_')[0] == request.auth.uid
                          || chatId.split('_')[1] == request.auth.uid);
      }
    }

    // reviews: 비활성화 (클라이언트 미사용)
    match /reviews/{reviewId} {
      allow read, write: if false;
    }

    // reports: 로그인 사용자 생성, 어드민 read/update/delete
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // 나머지 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
